# Core app
NODE_ENV=development
PORT=3000
FRONTEND_URL=https://phlakesfabrics.vercel.app
BACKEND_URL=https://phlakesfabrics-backend.onrender.com
NEXT_PUBLIC_APP_URL=https://phlakesfabrics-backend.onrender.com

# Mongo / auth
MONGODB_URI=mongodb://127.0.0.1:27017/phlakesfabrics
NEXTAUTH_URL=https://phlakesfabrics-backend.onrender.com
NEXTAUTH_SECRET=replace-with-a-long-random-secret
SESSION_SECRET=replace-with-a-long-random-secret
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Paystack
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
# Optional. If omitted, the webhook verifier falls back to PAYSTACK_SECRET_KEY.
PAYSTACK_WEBHOOK_SECRET=
PAYSTACK_CALLBACK_URL=https://phlakesfabrics.vercel.app/payment/callback

# Cloudinary uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional. Set this to use unsigned uploads and avoid needing the API secret for uploads.
CLOUDINARY_UPLOAD_PRESET=

# Resend mail
RESEND_API_KEY=

# Brevo mail
BREVO_API_KEY=
BREVO_API_BASE_URL=https://api.brevo.com/v3
# Use a verified Brevo sender address here before enabling Brevo in production.
BREVO_FROM=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=Phlakes Fabrics
BREVO_REPLY_TO_EMAIL=
BREVO_REPLY_TO_NAME=Phlakes Fabrics Support
BREVO_TIMEOUT_MS=30000
EMAIL_VERIFICATION_OTP_TTL_MINUTES=10

ADMIN_NOTIFICATION_EMAIL=
CONTACT_EMAIL=

# Optional admin bypass key for selected server routes
ADMIN_API_KEY=
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=Phlakes Fabrics Admin

# GIG Logistics
# Fill these with the production values for the merchant account you want to use.
GIG_BASE_URL=
GIG_EMAIL=
GIG_PASSWORD=
GIG_ORGANISATION=
GIG_USER_CHANNEL_CODE=
GIG_SENDER_NAME=
GIG_SENDER_PHONE_NUMBER=
GIG_SENDER_ADDRESS=
GIG_SENDER_LOCALITY=
GIG_SENDER_CITY=
GIG_SENDER_STATION_ID=
GIG_RECEIVER_STATION_ID=
GIG_DESTINATION_STATION_ID=
GIG_DESTINATION_SERVICE_CENTER_ID=
GIG_DEFAULT_ITEM_WEIGHT=1
# Optional JSON map keyed by "state::lga", "state::city", "lga", or "state"
# Example:
# GIG_STATION_MAP_JSON={"imo::lagos municipal":{"receiverStationId":4,"destinationStationId":4,"destinationServiceCenterId":14}}
GIG_STATION_MAP_JSON=
